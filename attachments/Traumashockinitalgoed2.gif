                        </div>
                        <div class="row text-center">
                          <h4 style="padding:10px;" class="modal-title">Welcome to MedicalDirector Access Control System</h4>
                        </div>

						<div class="row">
							<div class="col-xs-12">
								<ul class="list-group">
								  <li acc="36422" link="https://www.ciap.health.nsw.gov.au" class="list-group-item x-table-item x-account-link" style="border-bottom: none">
									    <div class="x-table-cell-item">
											<img class="pull-left x-photo" src="/ksLicensing/resources/default/images/NSW.png">
										</div>
									    <div class="x-table-cell-item">
											<h4 class="list-group-item-heading name" style="margin-top:10px;">New South Wales</h4>
											<p class="list-group-item-text title">If you are from <b>NSW Health</b>, please select here</p>
									    </div>												
									    <div class="x-table-cell-item" style="width: 20%">

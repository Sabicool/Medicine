    <script type="text/javascript" src="/ksLicensing/resources/default/js/jquery-1.8.2.min.js"></script>
	<script type="text/javascript">
		$(document).ready(function()
		{ 
			$(".x-account-link").click(function(){
				var redirectURL = 'https://www.uptodate.com.acs.hcn.com.au/services/app/contents/graphic/view/EM/76631/Traumashockinitalgoed2.gif';
				if (redirectURL === '')
					redirectURL = $(this).attr("link")
				var url;
				if(redirectURL.indexOf("?") != -1)
					url =  redirectURL + "&acc=" + $(this).attr("acc");
				else	
					url =  redirectURL + "?acc=" + $(this).attr("acc");
				location.href = url;
			});		
			
		});
	</script>	
  </body>
